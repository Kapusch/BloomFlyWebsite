---
import PracticeGrid from "../../components/PracticeGrid.astro";
import ScreenshotStrip from "../../components/ScreenshotStrip.astro";
import StoreBadges from "../../components/StoreBadges.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pageMeta } from "../../data/site";

const locale = "fr";
const meta = pageMeta[locale].discover;
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} path={meta.path} alternatePath={meta.alternate}>
  <section class="section page-hero">
    <div class="container page-hero-inner">
      <div>
        <p class="eyebrow">Découvrir</p>
        <h1>Des pratiques pour revenir à toi</h1>
        <p class="lead">Bloom & Fly rassemble des formats courts, guidés et visuels pour t’aider à respirer, te recentrer, traverser une émotion ou retrouver de l’énergie.</p>
        <StoreBadges locale={locale} />
      </div>
      <img src="/assets/illustrations/ritual-stress.png" alt="" width="1200" height="899" loading="eager" />
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Familles de pratiques</p>
      <h2>Choisis selon ton besoin du moment</h2>
      <PracticeGrid locale={locale} />
    </div>
  </section>

  <section class="section">
    <div class="container feature-grid">
      <article>
        <img src="/assets/illustrations/ritual-energy.png" alt="" width="1200" height="800" loading="lazy" />
        <h3>Rituels express</h3>
        <p>Quelques minutes pour calmer un pic, soutenir ton énergie ou préparer une transition dans ta journée.</p>
      </article>
      <article>
        <img src="/assets/illustrations/ritual-sleep.png" alt="" width="1200" height="800" loading="lazy" />
        <h3>Voyages et repos</h3>
        <p>Des expériences plus immersives pour relâcher le mental, te poser et retrouver un rythme plus doux.</p>
      </article>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Aperçu</p>
      <h2>Les pratiques dans l’application</h2>
      <ScreenshotStrip locale={locale} />
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(120deg, rgba(255, 241, 235, 0.95), rgba(223, 242, 251, 0.7));
  }

  .page-hero-inner,
  .feature-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.82fr);
    gap: 2rem;
    align-items: center;
  }

  .page-hero h1 {
    max-width: 11ch;
  }

  .page-hero img,
  .feature-grid img {
    width: 100%;
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .feature-grid article {
    display: grid;
    align-content: start;
    gap: 1rem;
  }

  .feature-grid h3,
  .feature-grid p {
    margin: 0;
  }

  @media (max-width: 820px) {
    .page-hero-inner,
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
