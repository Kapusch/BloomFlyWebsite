---
import ScreenshotStrip from "../../components/ScreenshotStrip.astro";
import StoreBadges from "../../components/StoreBadges.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pageMeta } from "../../data/site";
import { withBase } from "../../utils/paths";

const locale = "fr";
const meta = pageMeta[locale].discover;
const previewIntro = "Explore les pratiques qui te font du bien, à ton rythme.";

const practices = [
  {
    title: "Respirations",
    image: "/assets/icons/breaths.png",
    text:
      "Les respirations t’aident à apaiser ton mental, réduire le stress, retrouver ton équilibre intérieur et favoriser un meilleur sommeil. Dans Bloom & Fly, tu peux pratiquer des respirations guidées, ou créer ta propre respiration en choisissant ton rythme, ta durée et l’ambiance sonore qui t’apaise. Chaque pratique est accompagnée d’explications simples et d’animations visuelles.",
  },
  {
    title: "Mantras & affirmations positives",
    image: "/assets/icons/mantras.png",
    text:
      "Les mots ont le pouvoir d’apaiser, de réconforter et de transformer ton état d’esprit. Répétés régulièrement, ils t’aident à renforcer la confiance, à alléger le mental et à cultiver une énergie plus stable et positive au quotidien. Dans Bloom & Fly, les mantras sont organisés par besoins ou associés aux chakras, afin de t’accompagner selon ton état du moment. Tu peux également créer tes propres mantras pour exprimer ce dont tu as le plus besoin.",
  },
  {
    title: "Mudras",
    image: "/assets/icons/mudras.png",
    text:
      "Les mudras sont des gestes des mains qui invitent au calme, à la présence et à l’équilibre. Pratiqués avec attention, ils t’aident à relâcher les tensions, apaiser le mental et te recentrer. Dans Bloom & Fly, chaque mudra est présenté avec une explication claire, une illustration, ses bienfaits principaux et son lien avec les chakras, pour t’accompagner pas à pas.",
  },
  {
    title: "Chakras",
    image: "/assets/quick-access/quick-access-chakras.png",
    text:
      "Les chakras représentent la circulation de l’énergie dans le corps et influencent nos émotions, notre équilibre et notre vitalité. En explorant les sept chakras, tu découvriras leurs fonctions, leurs couleurs et les signes d’équilibre ou de déséquilibre. Tu apprendras à harmoniser chaque centre énergétique grâce aux mudras, mantras et pratiques associées.",
  },
  {
    title: "Sons & ambiances",
    image: "/assets/icons/music.png",
    text:
      "Écoute des sons et ambiances conçus pour accompagner tes moments de bien-être. Laisse la musique adoucir ton esprit, t’envelopper pendant une pratique, ou simplement t’apaiser au fil de ta journée, pour te recentrer, t’endormir plus sereinement ou créer une bulle de calme, où que tu sois.",
  },
];

const experiences = [
  {
    title: "Rituels express",
    image: "/assets/icons/rituals.png",
    text:
      "Offre-toi une pause de 3 minutes avec des pratiques guidées qui combinent plusieurs approches pour retrouver le calme, l'énergie ou préparer le sommeil. Idéal pour faire une pause, relâcher la pression ou retrouver un peu de sérénité au cœur de ta journée.",
  },
  {
    title: "Voyages guidés",
    image: "/assets/icons/journeys.png",
    text:
      "Prends davantage de temps pour toi avec des pratiques guidées qui combinent plusieurs approches autour d'un même thème, comme le calme, le sommeil, l'énergie, la joie ou la confiance. Idéal pour ralentir, te recentrer et t'offrir un véritable moment pour toi.",
  },
];
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} path={meta.path} alternatePath={meta.alternate}>
  <section class="section page-hero">
    <div class="container page-hero-inner">
      <div>
        <h1>Découvrir <span>ßloom & Fly</span></h1>
        <p class="hero-text">Bloom & Fly t’invite à respirer, ralentir et te reconnecter à toi.</p>
        <p class="hero-text">À travers des pratiques simples et guidées, l’application t’accompagne vers un bien-être plus profond, jour après jour.</p>
      </div>
      <img src={withBase("/assets/illustrations/mascot-premium-promo.png")} alt="" width="1692" height="1117" loading="eager" />
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Pratiques</p>
      <h2>Les pratiques au cœur de ßloom & Fly</h2>
      <p class="lead section-lead">Bloom & Fly réunit des pratiques complémentaires, chacune ayant son propre rôle dans ton bien-être. Découvre comment ces approches fonctionnent et se complètent pour t’accompagner au quotidien.</p>
      <div class="detail-list">
        {
          practices.map((practice) => (
            <article class="detail-item">
              <img src={withBase(practice.image)} alt="" width="180" height="180" loading="lazy" />
              <div>
                <h3>{practice.title}</h3>
                <p>{practice.text}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Programmes</p>
      <h2>Expériences guidées</h2>
      <p class="lead section-lead">Découvre des expériences guidées créées à partir des pratiques de Bloom & Fly. Chaque programme explore une thématique de bien-être : apaiser le stress, mieux dormir, retrouver ton énergie ou renforcer la confiance. Ils t’accompagnent pour retrouver équilibre et sérénité au quotidien.</p>
      <div class="experience-grid">
        {
          experiences.map((experience) => (
            <article class="card experience-card">
              <img src={withBase(experience.image)} alt="" width="160" height="160" loading="lazy" />
              <h3>{experience.title}</h3>
              <p>{experience.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft adaptive-section">
    <div class="container">
      <p class="eyebrow">Personnalisation</p>
      <h2>Une application qui s’adapte à toi</h2>
      <p class="lead section-lead">Bloom & Fly s’adapte à toi, à ton humeur et à ton temps disponible. Tu peux créer tes propres pratiques de respiration ou de mantra, ajouter tes favoris pour les retrouver facilement, et recevoir des rappels bienveillants pour garder ton élan. Tu peux aussi retrouver ton historique de pratiques et suivre ton activité au fil du temps.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Aperçu</p>
      <h2>Les pratiques dans l’application</h2>
      <p class="lead section-lead">{previewIntro}</p>
      <ScreenshotStrip locale={locale} />
    </div>
  </section>

  <section class="section section--soft download-section">
    <div class="narrow">
      <h2>Prêt·e à retrouver calme et joie au quotidien ?</h2>
      <StoreBadges locale={locale} compact mode="badges" />
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(120deg, rgba(255, 241, 235, 0.95), rgba(223, 242, 251, 0.7));
  }

  .page-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.72fr);
    gap: 2rem;
    align-items: center;
    padding-block: 1rem;
  }

  .page-hero h1 {
    max-width: 100%;
    font-size: clamp(3.4rem, 6.5vw, 5.3rem);
    line-height: 0.96;
  }

  .page-hero h1 span {
    white-space: nowrap;
  }

  .hero-text {
    max-width: 42rem;
    margin-bottom: 1rem;
    color: var(--dream);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .page-hero img {
    width: 100%;
    max-height: 28rem;
    object-fit: contain;
    border-radius: 8px;
  }

  .detail-list {
    display: grid;
    gap: 1.25rem;
    margin-top: 1.8rem;
  }

  .detail-item {
    display: grid;
    grid-template-columns: 7.5rem minmax(0, 1fr);
    gap: 1.35rem;
    align-items: center;
    width: 100%;
    padding: 1.45rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 18px 42px rgba(51, 56, 142, 0.08);
  }

  .detail-item img {
    justify-self: center;
    width: 6.25rem;
    height: 6.25rem;
    object-fit: contain;
    filter: drop-shadow(0 12px 22px rgba(51, 56, 142, 0.12));
  }

  .detail-item:nth-child(even) {
    grid-template-columns: minmax(0, 1fr) 7.5rem;
  }

  .detail-item:nth-child(even) img {
    grid-column: 2;
  }

  .detail-item:nth-child(even) div {
    grid-column: 1;
    grid-row: 1;
  }

  .experience-card img {
    justify-self: center;
    width: 5.4rem;
    height: 5.4rem;
    object-fit: contain;
  }

  .detail-item p,
  .experience-card p {
    margin-bottom: 0;
    font-size: clamp(1.08rem, 1.6vw, 1.24rem);
    line-height: 1.68;
  }

  .experience-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .experience-card {
    padding: 1.35rem;
  }

  .experience-card img {
    margin-bottom: 1rem;
  }

  .download-section {
    text-align: center;
  }

  .download-section :global(.store-cta) {
    justify-content: center;
    margin-top: 1.4rem;
  }

  .section-lead {
    max-width: 64rem;
    margin-bottom: 1.6rem;
  }

  @media (max-width: 820px) {
    .page-hero-inner,
    .experience-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .detail-item {
      grid-template-columns: 1fr;
      width: 100%;
      margin-right: 0;
      margin-left: 0;
    }

    .detail-item:nth-child(even) {
      grid-template-columns: 1fr;
    }

    .detail-item:nth-child(even) img,
    .detail-item:nth-child(even) div {
      grid-column: auto;
      grid-row: auto;
    }
  }
</style>
