---
import Hero from "../components/Hero.astro";
import PracticeGrid from "../components/PracticeGrid.astro";
import ScreenshotStrip from "../components/ScreenshotStrip.astro";
import StoreBadges from "../components/StoreBadges.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeContent, pageMeta, routes } from "../data/site";
import { withBase } from "../utils/paths";

const locale = "fr";
const content = homeContent[locale];
const meta = pageMeta[locale].home;
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} path={meta.path} alternatePath={meta.alternate}>
  <Hero locale={locale} />

  <section class="section">
    <div class="container">
      <p class="eyebrow">Au quotidien</p>
      <h2>{content.outcomesTitle}</h2>
      <p class="lead section-lead">{content.outcomesIntro}</p>
      <div class="grid grid--3 outcome-grid">
        {content.outcomes.map(([title, text, image]) => (
          <article class="card outcome">
            <img src={withBase(image)} alt="" width="180" height="180" loading="lazy" />
            <div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Pratiques</p>
      <h2>{content.practicesTitle}</h2>
      <p class="lead section-lead">{content.practicesIntro}</p>
      <a class="button button--ghost section-cta section-cta--top" href={withBase(routes.fr.discover)}>Découvrir les pratiques</a>
      <PracticeGrid locale={locale} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Dans l’application</p>
      <h2>{content.screenshotsTitle}</h2>
      <p class="lead section-lead">{content.screenshotsIntro}</p>
      <ScreenshotStrip locale={locale} />
    </div>
  </section>

  <section class="section story-section">
    <div class="container story">
      <div>
        <p class="eyebrow">Histoire</p>
        <h2>{content.storyTitle}</h2>
        <p class="lead">{content.story}</p>
        <a class="button button--ghost" href={withBase(routes.fr.about)}>À propos de Bloom & Fly</a>
      </div>
      <img src={withBase("/assets/brand/logo-pastille.png")} alt="" width="512" height="512" loading="lazy" />
    </div>
  </section>

  <section class="section final-cta">
    <div class="narrow">
      <h2>{content.finalTitle}</h2>
      <p class="lead">Télécharge Bloom & Fly et explore gratuitement les premières pratiques. L’essai premium de 7 jours te permet d’aller plus loin si tu le souhaites.</p>
      <StoreBadges locale={locale} compact mode="badges" />
    </div>
  </section>
</BaseLayout>

<style>
  .outcome {
    display: grid;
    grid-template-columns: 5.5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    min-height: 10.5rem;
    padding: 1.15rem;
    overflow: hidden;
  }

  .outcome img {
    width: 5.5rem;
    height: 5.5rem;
    object-fit: contain;
  }

  .outcome h3 {
    margin-bottom: 0.55rem;
  }

  .outcome p {
    margin-bottom: 0;
  }

  .story-section {
    background: linear-gradient(90deg, rgba(255, 241, 235, 0.88), rgba(223, 242, 251, 0.52));
  }

  .story {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(12rem, 20rem);
    gap: 2rem;
    align-items: center;
  }

  .story .button {
    margin-top: 1rem;
  }

  .section-cta {
    margin-top: 1.4rem;
  }

  .section-lead {
    max-width: 64rem;
    margin-bottom: 1.6rem;
  }

  .section-cta--top {
    margin-top: 0;
    margin-bottom: 1.6rem;
  }

  .story img {
    justify-self: center;
    width: min(18rem, 65vw);
    height: auto;
  }

  .final-cta {
    text-align: center;
  }

  .final-cta .lead {
    margin-inline: auto;
    margin-bottom: 1.6rem;
  }

  @media (max-width: 760px) {
    .story {
      grid-template-columns: 1fr;
      text-align: left;
    }
  }

  @media (max-width: 460px) {
    .outcome {
      grid-template-columns: 1fr;
    }
  }
</style>
