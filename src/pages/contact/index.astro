---
import StoreBadges from "../../components/StoreBadges.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pageMeta, site } from "../../data/site";
import { withBase } from "../../utils/paths";

const locale = "fr";
const meta = pageMeta[locale].contact;
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} path={meta.path} alternatePath={meta.alternate}>
  <section class="section contact-hero">
    <div class="container contact-layout">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>Contacte l’équipe ßloom & Fly</h1>
        <p class="lead">Pour une question, une demande de support, un partenariat ou un sujet presse, écris-nous directement par email.</p>
        <a class="button" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
      </div>
      <img src={withBase("/assets/illustrations/ritual-energy.png")} alt="" width="1200" height="800" loading="eager" />
    </div>
  </section>

  <section class="section">
    <div class="grid grid--3 container">
      <article class="card contact-card">
        <h3>Support</h3>
        <p>Un souci avec l’application, ton compte ou ton abonnement ? Indique ton appareil, ta plateforme et le contexte de la demande.</p>
      </article>
      <article class="card contact-card">
        <h3>Presse</h3>
        <p>Pour une demande média ou une présentation de Bloom & Fly, contacte-nous avec ton délai et ton support de publication.</p>
      </article>
      <article class="card contact-card">
        <h3>Partenariats</h3>
        <p>Pour une collaboration bien-être, contenu ou marque, partage quelques lignes sur ton projet.</p>
      </article>
    </div>
  </section>

  <section class="section section--soft final-cta">
    <div class="narrow">
      <h2>Envie d’essayer l’application ?</h2>
      <StoreBadges locale={locale} compact mode="badges" />
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    background: linear-gradient(120deg, rgba(255, 241, 235, 0.95), rgba(223, 242, 251, 0.65));
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.78fr);
    gap: 2rem;
    align-items: center;
  }

  .contact-layout h1 {
    max-width: 11ch;
  }

  .contact-layout .button {
    margin-top: 1rem;
  }

  .contact-layout img {
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .contact-card {
    padding: 1.35rem;
  }

  .contact-card p {
    margin-bottom: 0;
  }

  .final-cta {
    text-align: center;
  }

  @media (max-width: 820px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
