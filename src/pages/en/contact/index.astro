---
import StoreBadges from "../../../components/StoreBadges.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { pageMeta, site } from "../../../data/site";
import { withBase } from "../../../utils/paths";

const locale = "en";
const meta = pageMeta[locale].contact;
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} path={meta.path} alternatePath={meta.alternate}>
  <section class="section contact-hero">
    <div class="container contact-layout">
      <div>
        <h1>Contact the <span>ßloom & Fly</span> team</h1>
        <p class="lead">You can leave us a message through the form below, or write to us directly by email.</p>
        <a class="button" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
      </div>
      <img src={withBase("/assets/illustrations/bloomy-subscribe.png")} alt="" width="986" height="1077" loading="eager" />
    </div>
  </section>

  <section class="section contact-form-section">
    <div class="container contact-form-layout">
      <form class="contact-form card" data-contact-form data-contact-email={site.contactEmail}>
        <div class="field">
          <label for="name">Name <span aria-hidden="true">*</span></label>
          <input id="name" name="Name" type="text" autocomplete="name" maxlength="100" required />
        </div>

        <div class="field">
          <label for="email">Email <span aria-hidden="true">*</span></label>
          <input id="email" name="Email" type="email" autocomplete="email" required />
        </div>

        <div class="field">
          <label for="subject">Subject <span aria-hidden="true">*</span></label>
          <select id="subject" name="Subject" required>
            <option value="">Select an option</option>
            <option value="Support">Support</option>
            <option value="Press">Press</option>
            <option value="Partnerships">Partnerships</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="field">
          <label for="message">Tell us how we can help you <span aria-hidden="true">*</span></label>
          <p class="field-help">Share as much detail as you can so we can answer you properly.</p>
          <textarea id="message" name="Message" rows="6" required></textarea>
        </div>

        <button class="button" type="submit">Send</button>
      </form>

      <aside class="contact-aside">
        <p class="eyebrow">Write to us</p>
        <h2>We’ll reply as soon as possible</h2>
        <p class="lead">For support, include your device, platform, and what happened. For press or partnership requests, add your deadline and publication context.</p>
        <div class="contact-points">
          <article>
            <h3>Support</h3>
            <p>App, account, subscription, or technical issue.</p>
          </article>
          <article>
            <h3>Press</h3>
            <p>Bloom & Fly presentation, media request, or official information.</p>
          </article>
          <article>
            <h3>Partnerships</h3>
            <p>Wellbeing, content, brand, or editorial collaboration.</p>
          </article>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--soft final-cta">
    <div class="narrow">
      <h2>Want to try the app?</h2>
      <StoreBadges locale={locale} compact mode="badges" />
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector("[data-contact-form]");

  if (form instanceof HTMLFormElement) {
    form.addEventListener("submit", (event) => {
      event.preventDefault();

      if (!form.reportValidity()) return;

      const contactEmail = form.dataset.contactEmail;
      if (!contactEmail) return;

      const formData = new FormData(form);
      const name = String(formData.get("Name") ?? "").trim();
      const email = String(formData.get("Email") ?? "").trim();
      const subject = String(formData.get("Subject") ?? "").trim();
      const message = String(formData.get("Message") ?? "").trim();
      const mailSubject = `[Bloom & Fly] ${subject || "Contact"}`;
      const mailBody = [
        `Name: ${name}`,
        `Email: ${email}`,
        `Subject: ${subject}`,
        "",
        message,
      ].join("\n");

      window.location.href = `mailto:${contactEmail}?subject=${encodeURIComponent(mailSubject)}&body=${encodeURIComponent(mailBody)}`;
    });
  }
</script>

<style>
  .contact-hero {
    background: linear-gradient(120deg, rgba(255, 241, 235, 0.95), rgba(223, 242, 251, 0.65));
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 0.66fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding-block: 1rem;
  }

  .contact-layout h1 {
    max-width: 100%;
    font-size: clamp(3.5rem, 6.2vw, 5.4rem);
  }

  .contact-layout h1 span {
    white-space: nowrap;
  }

  .contact-layout .button {
    margin-top: 1rem;
    font-weight: 600;
  }

  .contact-layout img {
    justify-self: center;
    width: min(10.5rem, 42vw);
    border-radius: 8px;
    filter: drop-shadow(0 14px 26px rgba(51, 56, 142, 0.12));
  }

  .contact-form-section {
    background: linear-gradient(180deg, rgba(255, 250, 248, 0.7), rgba(223, 242, 251, 0.4));
  }

  .contact-form-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.4rem, 4vw, 2.4rem);
    align-items: start;
  }

  .contact-form {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.15rem;
    padding: clamp(1.35rem, 3vw, 2rem);
    overflow: hidden;
    border: 1px solid transparent;
    background:
      linear-gradient(rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.92)) padding-box,
      linear-gradient(135deg, rgba(95, 196, 213, 0.7), rgba(241, 146, 165, 0.42), rgba(51, 56, 142, 0.32)) border-box;
    box-shadow: 0 28px 70px rgba(51, 56, 142, 0.12);
  }

  .contact-form::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 0.35rem;
    background: linear-gradient(90deg, var(--aqua), var(--coral), var(--sun));
  }

  .field {
    display: grid;
    gap: 0.42rem;
  }

  .field:nth-child(n + 3),
  .contact-form .button {
    grid-column: 1 / -1;
  }

  label {
    color: var(--dream);
    font-weight: 850;
  }

  label span {
    color: var(--coral);
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid rgba(51, 56, 142, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.96);
    color: var(--ink);
    padding: 0.9rem 1rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  textarea {
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: 3px solid rgba(95, 196, 213, 0.24);
    border-color: var(--aqua);
    background: white;
    box-shadow: 0 10px 26px rgba(51, 56, 142, 0.08);
  }

  .field-help {
    margin-bottom: 0.2rem;
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .contact-form .button {
    width: fit-content;
    margin-top: 0.4rem;
    font-weight: 600;
    cursor: pointer;
  }

  .contact-aside {
    order: -1;
    padding-top: 0;
  }

  .contact-aside h2 {
    max-width: 100%;
  }

  .contact-aside .lead {
    max-width: 58rem;
  }

  .contact-points {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 1.6rem;
  }

  .contact-points article {
    padding: 1.05rem 1.15rem;
    border: 1px solid rgba(51, 56, 142, 0.1);
    border-left: 4px solid var(--aqua);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 14px 34px rgba(51, 56, 142, 0.06);
  }

  .contact-points h3 {
    margin-bottom: 0.35rem;
    font-size: 1.3rem;
  }

  .contact-points p {
    margin-bottom: 0;
  }

  .final-cta {
    text-align: center;
  }

  @media (max-width: 820px) {
    .contact-layout,
    .contact-points {
      grid-template-columns: 1fr;
    }

    .contact-form {
      grid-template-columns: 1fr;
    }
  }
</style>
