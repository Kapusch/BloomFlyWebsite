---
import ScreenshotStrip from "../../../components/ScreenshotStrip.astro";
import StoreBadges from "../../../components/StoreBadges.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { pageMeta } from "../../../data/site";
import { withBase } from "../../../utils/paths";

const locale = "en";
const meta = pageMeta[locale].discover;
const previewIntro = "Explore the practices that help you feel good, at your own pace.";

const practices = [
  {
    title: "Breathing practices",
    image: "/assets/icons/breaths.png",
    text:
      "Breathing exercises help you calm your mind, reduce stress, restore your inner balance, and support better sleep. In Bloom & Fly, you can follow guided breathing exercises or create your own by choosing your rhythm, duration, and the soundscape that helps you relax. Each practice is accompanied by clear explanations and visual animations.",
  },
  {
    title: "Mantras & positive affirmations",
    image: "/assets/icons/mantras.png",
    text:
      "Words have the power to soothe, comfort, and transform your state of mind. When repeated regularly, they help strengthen confidence, lighten the mental load, and cultivate a more stable, positive energy in everyday life. In Bloom & Fly, mantras are organized by needs or associated with chakras, so they can support you according to how you’re feeling in the moment. You can also create your own mantras to express what you need most.",
  },
  {
    title: "Mudras",
    image: "/assets/icons/mudras.png",
    text:
      "Mudras are hand gestures that invite calm, presence, and balance. Practiced mindfully, they help release tension, soothe the mind, and bring you back to center. In Bloom & Fly, each mudra is presented with a clear explanation, an illustration, its main benefits, and its connection to the chakras, to guide you step by step.",
  },
  {
    title: "Chakras",
    image: "/assets/quick-access/quick-access-chakras.png",
    text:
      "Chakras represent the flow of energy within the body and influence our emotions, balance, and vitality. By exploring the seven chakras, you will discover their functions, colors, and the signs of balance or imbalance. You will learn how to harmonize each energy center through the mudras, mantras, and associated practices.",
  },
  {
    title: "Sounds & ambiences",
    image: "/assets/icons/music.png",
    text:
      "Listen to sounds and ambiences designed to support your moments of well-being. Let the music soften your mind, envelop you during a practice, or calm you throughout your day, helping you recenter, fall asleep more peacefully, or create a bubble of quiet wherever you are.",
  },
];

const experiences = [
  {
    title: "Express rituals",
    image: "/assets/icons/rituals.png",
    text:
      "Take a 3-minute break with guided practices that combine different approaches to help you find calm, restore your energy, or prepare for sleep. Perfect for taking a break, releasing tension, or bringing a little more calm to your day.",
  },
  {
    title: "Guided journeys",
    image: "/assets/icons/journeys.png",
    text:
      "Take more time for yourself with guided practices that combine different approaches around a single theme, such as calm, sleep, energy, joy, or confidence. Perfect for slowing down, refocusing, and giving yourself a true moment of self-care.",
  },
];
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} path={meta.path} alternatePath={meta.alternate}>
  <section class="section page-hero">
    <div class="container page-hero-inner">
      <div>
        <h1>Discover <span>ßloom & Fly</span></h1>
        <p class="hero-text">Bloom & Fly invites you to breathe, slow down, and reconnect with yourself.</p>
        <p class="hero-text">Through simple, guided practices, the app supports you in cultivating deeper well-being, day after day.</p>
      </div>
      <img src={withBase("/assets/illustrations/mascot-premium-promo.png")} alt="" width="1692" height="1117" loading="eager" />
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Practices</p>
      <h2>The practices at the heart of ßloom & Fly</h2>
      <p class="lead section-lead">Bloom & Fly brings together complementary practices, each playing its own role in your well-being. Discover how these approaches work and complement one another to support you in your daily life.</p>
      <div class="detail-list">
        {
          practices.map((practice) => (
            <article class="detail-item">
              <img src={withBase(practice.image)} alt="" width="180" height="180" loading="lazy" />
              <div>
                <h3>{practice.title}</h3>
                <p>{practice.text}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Programs</p>
      <h2>Guided experiences</h2>
      <p class="lead section-lead">Discover guided experiences created from Bloom & Fly’s well-being practices. Each program explores a well-being theme: easing stress, sleeping better, restoring energy, or strengthening confidence. They support you in finding balance and serenity in everyday life.</p>
      <div class="experience-grid">
        {
          experiences.map((experience) => (
            <article class="card experience-card">
              <img src={withBase(experience.image)} alt="" width="160" height="160" loading="lazy" />
              <h3>{experience.title}</h3>
              <p>{experience.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--soft adaptive-section">
    <div class="container">
      <p class="eyebrow">Personalization</p>
      <h2>An app that adapts to you</h2>
      <p class="lead section-lead">Bloom & Fly adapts to you, to your mood and the time you have. You can create your own breathing or mantra practices, add favorites to find them easily, and receive gentle reminders to help you keep your momentum. You can also revisit your practice history and track your activity over time.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Preview</p>
      <h2>Practices inside the app</h2>
      <p class="lead section-lead">{previewIntro}</p>
      <ScreenshotStrip locale={locale} />
    </div>
  </section>

  <section class="section section--soft download-section">
    <div class="narrow">
      <h2>Ready to rediscover calm and joy in your daily life?</h2>
      <StoreBadges locale={locale} compact mode="badges" />
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(120deg, rgba(255, 241, 235, 0.95), rgba(223, 242, 251, 0.7));
  }

  .page-hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.72fr);
    gap: 2rem;
    align-items: center;
    padding-block: 1rem;
  }

  .page-hero h1 {
    max-width: 100%;
    font-size: clamp(3.4rem, 6.5vw, 5.3rem);
    line-height: 0.96;
  }

  .page-hero h1 span {
    white-space: nowrap;
  }

  .hero-text {
    max-width: 42rem;
    margin-bottom: 1rem;
    color: var(--dream);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .page-hero img {
    width: 100%;
    max-height: 28rem;
    object-fit: contain;
    border-radius: 8px;
  }

  .detail-list {
    display: grid;
    gap: 1.25rem;
    margin-top: 1.8rem;
  }

  .detail-item {
    display: grid;
    grid-template-columns: 7.5rem minmax(0, 1fr);
    gap: 1.35rem;
    align-items: center;
    width: 100%;
    padding: 1.45rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 18px 42px rgba(51, 56, 142, 0.08);
  }

  .detail-item img {
    justify-self: center;
    width: 6.25rem;
    height: 6.25rem;
    object-fit: contain;
    filter: drop-shadow(0 12px 22px rgba(51, 56, 142, 0.12));
  }

  .detail-item:nth-child(even) {
    grid-template-columns: minmax(0, 1fr) 7.5rem;
  }

  .detail-item:nth-child(even) img {
    grid-column: 2;
  }

  .detail-item:nth-child(even) div {
    grid-column: 1;
    grid-row: 1;
  }

  .experience-card img {
    justify-self: center;
    width: 5.4rem;
    height: 5.4rem;
    object-fit: contain;
  }

  .detail-item p,
  .experience-card p {
    margin-bottom: 0;
    font-size: clamp(1.08rem, 1.6vw, 1.24rem);
    line-height: 1.68;
  }

  .experience-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .experience-card {
    padding: 1.35rem;
  }

  .experience-card img {
    margin-bottom: 1rem;
  }

  .download-section {
    text-align: center;
  }

  .download-section :global(.store-cta) {
    justify-content: center;
    margin-top: 1.4rem;
  }

  .section-lead {
    max-width: 64rem;
    margin-bottom: 1.6rem;
  }

  @media (max-width: 820px) {
    .page-hero-inner,
    .experience-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .detail-item {
      grid-template-columns: 1fr;
      width: 100%;
      margin-right: 0;
      margin-left: 0;
    }

    .detail-item:nth-child(even) {
      grid-template-columns: 1fr;
    }

    .detail-item:nth-child(even) img,
    .detail-item:nth-child(even) div {
      grid-column: auto;
      grid-row: auto;
    }
  }
</style>
