---
import PracticeGrid from "../../../components/PracticeGrid.astro";
import ScreenshotStrip from "../../../components/ScreenshotStrip.astro";
import StoreBadges from "../../../components/StoreBadges.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { pageMeta } from "../../../data/site";

const locale = "en";
const meta = pageMeta[locale].discover;
---

<BaseLayout locale={locale} title={meta.title} description={meta.description} path={meta.path} alternatePath={meta.alternate}>
  <section class="section page-hero">
    <div class="container page-hero-inner">
      <div>
        <p class="eyebrow">Discover</p>
        <h1>Practices to come back to yourself</h1>
        <p class="lead">Bloom & Fly brings together short, guided, visual formats to help you breathe, settle, move through emotions, or restore energy.</p>
        <StoreBadges locale={locale} />
      </div>
      <img src="/assets/illustrations/ritual-stress.png" alt="" width="1200" height="899" loading="eager" />
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Practice families</p>
      <h2>Choose what you need now</h2>
      <PracticeGrid locale={locale} />
    </div>
  </section>

  <section class="section">
    <div class="container feature-grid">
      <article>
        <img src="/assets/illustrations/ritual-energy.png" alt="" width="1200" height="800" loading="lazy" />
        <h3>Express rituals</h3>
        <p>A few minutes to calm a wave, support your energy, or prepare a transition in your day.</p>
      </article>
      <article>
        <img src="/assets/illustrations/ritual-sleep.png" alt="" width="1200" height="800" loading="lazy" />
        <h3>Journeys and rest</h3>
        <p>More immersive experiences to soften mental noise, settle down, and return to a gentler rhythm.</p>
      </article>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Preview</p>
      <h2>Practices inside the app</h2>
      <ScreenshotStrip locale={locale} />
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(120deg, rgba(255, 241, 235, 0.95), rgba(223, 242, 251, 0.7));
  }

  .page-hero-inner,
  .feature-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.82fr);
    gap: 2rem;
    align-items: center;
  }

  .page-hero h1 {
    max-width: 11ch;
  }

  .page-hero img,
  .feature-grid img {
    width: 100%;
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .feature-grid article {
    display: grid;
    align-content: start;
    gap: 1rem;
  }

  .feature-grid h3,
  .feature-grid p {
    margin: 0;
  }

  @media (max-width: 820px) {
    .page-hero-inner,
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
