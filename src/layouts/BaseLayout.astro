---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, type Locale } from "../data/site";
import { withBase } from "../utils/paths";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  path: string;
  alternatePath?: string;
  noindex?: boolean;
}

const { locale, title, description, path, alternatePath, noindex = false } = Astro.props;
const canonical = new URL(path, site.baseUrl).toString();
const alternate = alternatePath ? new URL(alternatePath, site.baseUrl).toString() : undefined;
const ogImage = new URL("/assets/og/bloomfly-og.png", site.baseUrl).toString();
const alternateLang = locale === "fr" ? "en" : "fr";
const regularFont = withBase("/assets/fonts/Nunito-VariableFont_wght.ttf");
const italicFont = withBase("/assets/fonts/Nunito-Italic-VariableFont_wght.ttf");
const fontFaces = `
  @font-face {
    font-family: "Nunito";
    src: url("${regularFont}") format("truetype");
    font-style: normal;
    font-weight: 200 1000;
    font-display: swap;
  }

  @font-face {
    font-family: "Nunito";
    src: url("${italicFont}") format("truetype");
    font-style: italic;
    font-weight: 200 1000;
    font-display: swap;
  }
`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
    <meta name="google-site-verification" content="ZNb8EFIMd5_V48wQVEWZIeqzgh_bncY4bDZeEQCrRMc" />
    <link rel="canonical" href={canonical} />
    {alternate && <link rel="alternate" hreflang={alternateLang} href={alternate} />}
    <link rel="alternate" hreflang={locale} href={canonical} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", site.baseUrl).toString()} />
    <link rel="icon" type="image/png" href={withBase("/assets/brand/logo-icon.png")} />
    <meta property="og:site_name" content="Bloom & Fly" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === "fr" ? "fr_FR" : "en_US"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <style is:inline set:html={fontFaces}></style>
    <style is:global>
      :root {
        color-scheme: light;
        --dream: #33388e;
        --dream-deep: #22265f;
        --sky: #dff2fb;
        --aqua: #5fc4d5;
        --peach: #fff1eb;
        --coral: #f192a5;
        --sun: #eda246;
        --ink: #202457;
        --muted: rgba(32, 36, 87, 0.72);
        --surface: rgba(255, 255, 255, 0.82);
        --line: rgba(51, 56, 142, 0.14);
        --shadow: 0 24px 70px rgba(51, 56, 142, 0.15);
        font-family: "Nunito", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f9fcfd;
        color: var(--ink);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-width: 320px;
        background:
          linear-gradient(180deg, rgba(223, 242, 251, 0.7) 0%, #fffaf8 42%, #f7fbfd 100%);
        color: var(--ink);
      }

      body,
      button,
      input,
      textarea {
        font: inherit;
      }

      img {
        display: block;
        max-width: 100%;
        height: auto;
      }

      a {
        color: inherit;
      }

      .page {
        overflow: hidden;
      }

      .section {
        padding: clamp(4rem, 9vw, 7rem) 1.25rem;
      }

      .section--soft {
        background: linear-gradient(180deg, rgba(255, 241, 235, 0.66), rgba(223, 242, 251, 0.45));
      }

      .container {
        width: min(1120px, 100%);
        margin: 0 auto;
      }

      .narrow {
        width: min(820px, 100%);
        margin: 0 auto;
      }

      .eyebrow {
        margin: 0 0 0.8rem;
        color: var(--aqua);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        max-width: 12ch;
        margin-bottom: 1.1rem;
        color: var(--dream);
        font-size: clamp(3.3rem, 9vw, 7.4rem);
        line-height: 0.92;
        letter-spacing: 0;
      }

      h2 {
        margin-bottom: 1rem;
        color: var(--dream);
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: 1;
        letter-spacing: 0;
      }

      h3 {
        color: var(--dream);
        font-size: 1.35rem;
        line-height: 1.16;
        letter-spacing: 0;
      }

      p,
      li {
        color: var(--muted);
        font-size: 1.04rem;
        line-height: 1.72;
      }

      .lead {
        max-width: 42rem;
        color: rgba(32, 36, 87, 0.8);
        font-size: clamp(1.15rem, 2vw, 1.35rem);
        line-height: 1.65;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3.35rem;
        padding: 0.85rem 1.35rem;
        border: 0;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--dream), #247fb2 55%, var(--aqua));
        color: white;
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 16px 34px rgba(51, 56, 142, 0.22);
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          background 180ms ease;
      }

      .button:hover,
      .button:focus-visible {
        transform: translateY(-2px);
        box-shadow: 0 20px 42px rgba(51, 56, 142, 0.28);
      }

      .button--ghost {
        background: rgba(255, 255, 255, 0.82);
        color: var(--dream);
        box-shadow: inset 0 0 0 1px var(--line);
      }

      .grid {
        display: grid;
        gap: 1rem;
      }

      .grid--3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .grid--2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .card {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.74);
        box-shadow: 0 16px 40px rgba(51, 56, 142, 0.08);
      }

      .skip-link {
        position: fixed;
        left: 1rem;
        top: 1rem;
        z-index: 20;
        transform: translateY(-150%);
        padding: 0.75rem 1rem;
        border-radius: 999px;
        background: var(--dream);
        color: white;
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      @media (max-width: 820px) {
        .section {
          padding: 3.5rem 1rem;
        }

        .grid--3,
        .grid--2 {
          grid-template-columns: 1fr;
        }

        h1 {
          max-width: 9ch;
        }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#content">{locale === "fr" ? "Aller au contenu" : "Skip to content"}</a>
    <Header locale={locale} />
    <main id="content" class="page">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
