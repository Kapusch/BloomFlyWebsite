---
import { type Locale } from "../data/site";
import { withBase } from "../utils/paths";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const prefix = locale === "fr" ? "fr" : "en";
const screenshots = [
  [`/assets/screens/${prefix}-breath.png`, locale === "fr" ? "Respiration guidée" : "Guided breathing"],
  [`/assets/screens/${prefix}-mantra.png`, locale === "fr" ? "Mantras" : "Mantras"],
  [`/assets/screens/${prefix}-mudra.png`, locale === "fr" ? "Mudras" : "Mudras"],
  [`/assets/screens/${prefix}-journey.png`, locale === "fr" ? "Voyages guidés" : "Guided journeys"],
];
---

<div class="screenshots">
  {
    screenshots.map(([src, label]) => (
      <figure>
        <img src={withBase(src)} alt={label} width="414" height="900" loading="lazy" />
        <figcaption>{label}</figcaption>
      </figure>
    ))
  }
</div>

<style>
  .screenshots {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    align-items: stretch;
  }

  figure {
    display: grid;
    align-content: start;
    margin: 0;
  }

  img {
    width: 100%;
    height: auto;
    border: 8px solid rgba(255, 255, 255, 0.9);
    border-radius: 1.6rem;
    background: white;
    box-shadow: 0 20px 44px rgba(51, 56, 142, 0.14);
  }

  figcaption {
    margin-top: 0.7rem;
    color: var(--dream);
    font-size: 0.95rem;
    font-weight: 850;
    text-align: center;
  }

  @media (max-width: 860px) {
    .screenshots {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .screenshots {
      grid-template-columns: 1fr;
      width: min(19rem, 100%);
      margin: 0 auto;
    }
  }
</style>
