---
interface Props {
  to: string;
  label: string;
}

const { to, label } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${to}`} />
    <link rel="canonical" href={to} />
    <script is:inline>{`window.location.replace(${JSON.stringify(to)});`}</script>
    <title>{label}</title>
  </head>
  <body>
    <p><a href={to}>{label}</a></p>
  </body>
</html>
