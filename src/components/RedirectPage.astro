---
import { withBase } from "../utils/paths";

interface Props {
  to: string;
  label: string;
}

const { to, label } = Astro.props;
const redirectTo = withBase(to);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${redirectTo}`} />
    <link rel="canonical" href={redirectTo} />
    <script is:inline>{`window.location.replace(${JSON.stringify(redirectTo)});`}</script>
    <title>{label}</title>
  </head>
  <body>
    <p><a href={redirectTo}>{label}</a></p>
  </body>
</html>
