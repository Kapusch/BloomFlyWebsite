---
import { labels, routes, site, type Locale } from "../data/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = labels[locale];
const r = routes[locale];
const alternateHref = locale === "fr" ? routes.en.home : routes.fr.home;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/assets/brand/logo-horizontal.png" alt="Bloom & Fly" width="300" height="44" loading="lazy" />
      <p>
        {locale === "fr"
          ? "Respirations guidées, mantras, mudras, rituels express et voyages intérieurs pour prendre soin de toi au quotidien."
          : "Guided breathing, mantras, mudras, express rituals, and inner journeys for everyday wellbeing."}
      </p>
    </div>

    <nav aria-label={locale === "fr" ? "Navigation du pied de page" : "Footer navigation"}>
      <p class="footer-title">{locale === "fr" ? "Bloom & Fly" : "Bloom & Fly"}</p>
      <a href={r.home}>{t.nav.home}</a>
      <a href={r.discover}>{t.nav.discover}</a>
      <a href={r.about}>{t.nav.about}</a>
      <a href={r.contact}>{t.nav.contact}</a>
    </nav>

    <nav aria-label={t.footerLegal}>
      <p class="footer-title">{t.footerLegal}</p>
      <a href={r.legalNotices}>{locale === "fr" ? "Mentions légales" : "Legal Notices"}</a>
      <a href={r.privacyPolicy}>{locale === "fr" ? "Politique de confidentialité" : "Privacy Policy"}</a>
      <a href={r.termsOfService}>{locale === "fr" ? "CGU" : "Terms of Service"}</a>
      <a href={r.termsOfSale}>{locale === "fr" ? "CGV" : "Terms of Sale"}</a>
    </nav>

    <div>
      <p class="footer-title">{t.contact}</p>
      <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
      <p class="footer-title follow">{t.follow}</p>
      <a href={site.socials.instagram}>Instagram</a>
      <a href={site.socials.facebook}>Facebook</a>
      <p class="footer-title follow">{locale === "fr" ? "Langue" : "Language"}</p>
      <a href={alternateHref}>{t.switchLabel}</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 1.25rem 2rem;
    background: #f6fbfd;
    border-top: 1px solid rgba(51, 56, 142, 0.1);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) repeat(3, minmax(0, 1fr));
    gap: 2rem;
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .footer-brand img {
    width: min(15rem, 100%);
    height: auto;
    margin-bottom: 1rem;
  }

  .footer-brand p {
    max-width: 24rem;
    margin-bottom: 0;
  }

  nav,
  .site-footer div:not(.footer-inner):not(.footer-brand) {
    display: grid;
    align-content: start;
    gap: 0.58rem;
  }

  .footer-title {
    margin: 0 0 0.15rem;
    color: var(--dream);
    font-size: 0.92rem;
    font-weight: 900;
  }

  .follow {
    margin-top: 1.1rem;
  }

  a {
    color: rgba(32, 36, 87, 0.78);
    text-decoration: none;
  }

  a:hover,
  a:focus-visible {
    color: var(--dream);
    text-decoration: underline;
  }

  @media (max-width: 820px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
