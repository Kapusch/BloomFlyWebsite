---
import { labels, routes, site, type Locale } from "../data/site";
import { withBase } from "../utils/paths";

interface Props {
  locale: Locale;
  alternatePath?: string;
}

const { locale, alternatePath } = Astro.props;
const t = labels[locale];
const r = routes[locale];
const alternateHref = alternatePath ?? (locale === "fr" ? routes.en.home : routes.fr.home);
const socialLinks = [
  ["instagram", "Instagram", site.socials[locale].instagram],
  ["facebook", "Facebook", site.socials[locale].facebook],
  ["tiktok", "TikTok", site.socials[locale].tiktok],
] as const;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src={withBase("/assets/brand/logo-pastille-dream-blue.png")} alt="Bloom & Fly" width="512" height="512" loading="lazy" />
      <button class="footer-cta" type="button" data-download-open>{t.cta.primary}</button>
    </div>

    <nav aria-label={locale === "fr" ? "Navigation du pied de page" : "Footer navigation"}>
      <p class="footer-title">{locale === "fr" ? "Bloom & Fly" : "Bloom & Fly"}</p>
      <a href={withBase(r.home)}>{t.nav.home}</a>
      <a href={withBase(r.discover)}>{t.nav.discover}</a>
      <a href={withBase(r.about)}>{t.nav.about}</a>
    </nav>

    <nav aria-label={locale === "fr" ? "Aide et contact" : "Help and contact"}>
      <p class="footer-title">{locale === "fr" ? "Aide & contact" : "Help & contact"}</p>
      <a href={withBase(r.contact)}>{locale === "fr" ? "Page de contact" : "Contact page"}</a>
    </nav>

    <nav aria-label={t.footerLegal}>
      <p class="footer-title">{locale === "fr" ? "Légal" : "Legal"}</p>
      <a href={withBase(r.legalNotices)}>{locale === "fr" ? "Mentions légales" : "Legal Notices"}</a>
      <a href={withBase(r.privacyPolicy)}>{locale === "fr" ? "Politique de confidentialité" : "Privacy Policy"}</a>
      <a href={withBase(r.termsOfService)}>{locale === "fr" ? "CGU" : "Terms of Service"}</a>
      <a href={withBase(r.termsOfSale)}>{locale === "fr" ? "CGV" : "Terms of Sale"}</a>
    </nav>

    <div class="footer-social">
      <div class="social-links" aria-label={t.follow}>
        {
          socialLinks.map(([key, label, href]) => (
            <a href={href} aria-label={label} title={label} target="_blank" rel="noopener noreferrer">
              {key === "instagram" && (
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <rect x="5" y="5" width="14" height="14" rx="4" />
                  <circle cx="12" cy="12" r="3.2" />
                  <path d="M16.6 7.8h.01" />
                </svg>
              )}
              {key === "facebook" && (
                <svg aria-hidden="true" viewBox="0 0 448 512">
                  <path d="M400 32H48A48 48 0 0 0 0 80v352a48 48 0 0 0 48 48h137V328h-63v-72h63v-55c0-62 37-96 94-96 27 0 55 5 55 5v61h-31c-31 0-40 19-40 39v46h69l-11 72h-58v152h137a48 48 0 0 0 48-48V80a48 48 0 0 0-48-48Z" />
                </svg>
              )}
              {key === "tiktok" && (
                <svg aria-hidden="true" viewBox="0 0 448 512">
                  <path d="M448 210a210 210 0 0 1-123-39v157a143 143 0 1 1-123-142v79a66 66 0 1 0 45 63V0h78a132 132 0 0 0 123 118v92Z" />
                </svg>
              )}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="language-switch" aria-label={locale === "fr" ? "Changer de langue" : "Change language"}>
      <span aria-current="true">{t.langName}</span>
      <a href={withBase(alternateHref)}>{t.switchLabel}</a>
    </div>
    <p>Copyright © 2026 Bloom & Fly App</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 1.25rem 2.2rem;
    background:
      linear-gradient(180deg, rgba(246, 251, 253, 0.95), rgba(232, 246, 251, 0.9));
    border-top: 1px solid rgba(51, 56, 142, 0.1);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(12.5rem, 0.95fr) minmax(0, 1.15fr) minmax(0, 1fr) minmax(0, 1.2fr) auto;
    gap: clamp(1.7rem, 4vw, 3.2rem);
    width: min(1120px, 100%);
    margin: 0 auto;
    padding: clamp(2rem, 4.8vw, 3rem);
    border: 1px solid rgba(51, 56, 142, 0.1);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 22px 60px rgba(51, 56, 142, 0.08);
  }

  .footer-brand img {
    width: min(9rem, 100%);
    height: auto;
    margin-bottom: 1.1rem;
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    width: max-content;
    max-width: 100%;
    padding: 0.72rem 1rem;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--dream), #247fb2 58%, var(--aqua));
    color: white;
    font-weight: 600;
    white-space: nowrap;
    cursor: pointer;
    box-shadow: 0 12px 28px rgba(51, 56, 142, 0.18);
  }

  .footer-brand {
    display: grid;
    width: max-content;
    max-width: 100%;
    align-content: start;
    justify-items: center;
  }

  nav {
    display: grid;
    align-content: start;
    gap: 0.58rem;
  }

  .footer-title {
    margin: 0 0 0.75rem;
    color: var(--dream);
    font-size: 1.12rem;
    font-weight: 820;
  }

  .footer-social {
    display: flex;
    align-self: start;
    justify-content: flex-end;
    padding-top: 0.05rem;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.72rem;
  }

  .social-links a {
    display: inline-grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 7px;
    background: var(--dream);
    color: white;
    box-shadow: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .social-links a:hover,
  .social-links a:focus-visible {
    background: #247fb2;
    color: white;
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 16px 32px rgba(51, 56, 142, 0.24);
  }

  .social-links svg {
    width: 1.28rem;
    height: 1.28rem;
    fill: currentColor;
  }

  .social-links a[aria-label="Instagram"] svg {
    width: 1.55rem;
    height: 1.55rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.2;
  }

  a {
    color: var(--dream);
    text-decoration: none;
    font-size: 1.08rem;
    line-height: 1.45;
  }

  a:hover,
  a:focus-visible {
    color: var(--dream);
    text-decoration: underline;
  }

  .footer-bottom {
    display: grid;
    justify-items: center;
    gap: 1.1rem;
    width: min(1120px, 100%);
    margin: 1.6rem auto 0;
  }

  .footer-bottom p {
    margin: 0;
    color: var(--dream);
    font-size: 0.96rem;
    font-weight: 740;
  }

  .language-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    min-height: 3.1rem;
    padding: 0.32rem;
    border-radius: 999px;
    background: white;
    box-shadow:
      inset 0 0 0 1px rgba(51, 56, 142, 0.12),
      0 14px 32px rgba(51, 56, 142, 0.08);
  }

  .language-switch span,
  .language-switch a {
    min-width: 6.2rem;
    padding: 0.65rem 1rem;
    border-radius: 999px;
    color: var(--dream);
    font-weight: 650;
    text-align: center;
    text-decoration: none;
  }

  .language-switch span {
    background: linear-gradient(135deg, rgba(51, 56, 142, 0.96), rgba(36, 127, 178, 0.94));
    color: white;
  }

  .language-switch a:hover,
  .language-switch a:focus-visible {
    background: rgba(95, 196, 213, 0.13);
    text-decoration: none;
  }

  @media (max-width: 820px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand,
    .footer-social {
      grid-column: 1 / -1;
    }

    .footer-social {
      justify-content: flex-start;
    }
  }

  @media (max-width: 560px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
