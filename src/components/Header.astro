---
import { labels, routes, type Locale } from "../data/site";
import { withBase } from "../utils/paths";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = labels[locale];
const r = routes[locale];
const alternateHref = locale === "fr" ? routes.en.home : routes.fr.home;
---

<header class="site-header">
  <a class="brand" href={withBase(r.home)} aria-label="Bloom & Fly">
    <img src={withBase("/assets/brand/logo-horizontal.png")} alt="Bloom & Fly" width="300" height="44" />
  </a>

  <nav class="desktop-nav" aria-label={locale === "fr" ? "Navigation principale" : "Main navigation"}>
    <a href={withBase(r.home)}>{t.nav.home}</a>
    <a href={withBase(r.discover)}>{t.nav.discover}</a>
    <a href={withBase(r.about)}>{t.nav.about}</a>
    <a href={withBase(r.contact)}>{t.nav.contact}</a>
  </nav>

  <div class="header-actions">
    <a class="language" href={withBase(alternateHref)}>{t.switchLabel}</a>
    <details class="mobile-menu">
      <summary aria-label={locale === "fr" ? "Ouvrir le menu" : "Open menu"}>
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <nav aria-label={locale === "fr" ? "Navigation mobile" : "Mobile navigation"}>
        <a href={withBase(r.home)}>{t.nav.home}</a>
        <a href={withBase(r.discover)}>{t.nav.discover}</a>
        <a href={withBase(r.about)}>{t.nav.about}</a>
        <a href={withBase(r.contact)}>{t.nav.contact}</a>
        <a href={withBase(alternateHref)}>{t.switchLabel}</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    min-height: 4.8rem;
    padding: 0.85rem max(1rem, calc((100vw - 1120px) / 2));
    border-bottom: 1px solid rgba(51, 56, 142, 0.09);
    background: rgba(249, 252, 253, 0.86);
    backdrop-filter: blur(16px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    text-decoration: none;
  }

  .brand img {
    width: clamp(10rem, 18vw, 17.5rem);
    height: auto;
  }

  .desktop-nav,
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .desktop-nav a,
  .language {
    min-height: 2.5rem;
    padding: 0.65rem 0.85rem;
    border-radius: 999px;
    color: var(--dream);
    font-weight: 800;
    text-decoration: none;
  }

  .desktop-nav a:hover,
  .desktop-nav a:focus-visible,
  .language:hover,
  .language:focus-visible {
    background: rgba(95, 196, 213, 0.14);
  }

  .language {
    box-shadow: inset 0 0 0 1px rgba(51, 56, 142, 0.14);
  }

  .mobile-menu {
    display: none;
    position: relative;
  }

  .mobile-menu summary {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.24rem;
    width: 2.7rem;
    height: 2.7rem;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: white;
    box-shadow: inset 0 0 0 1px rgba(51, 56, 142, 0.14);
    cursor: pointer;
    list-style: none;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu span {
    display: block;
    width: 1.18rem;
    height: 0.13rem;
    border-radius: 999px;
    background: var(--dream);
  }

  .mobile-menu nav {
    position: absolute;
    right: 0;
    top: calc(100% + 0.65rem);
    display: grid;
    min-width: 13rem;
    padding: 0.55rem;
    border: 1px solid rgba(51, 56, 142, 0.12);
    border-radius: 8px;
    background: white;
    box-shadow: var(--shadow);
  }

  .mobile-menu nav a {
    padding: 0.75rem 0.85rem;
    border-radius: 8px;
    color: var(--dream);
    font-weight: 800;
    text-decoration: none;
  }

  .mobile-menu nav a:hover,
  .mobile-menu nav a:focus-visible {
    background: rgba(95, 196, 213, 0.12);
  }

  @media (max-width: 760px) {
    .desktop-nav,
    .header-actions > .language {
      display: none;
    }

    .mobile-menu {
      display: block;
    }
  }
</style>
