---
import { practices, type Locale } from "../data/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const items = practices[locale];
---

<div class="practice-grid">
  {
    items.map(([title, description, icon]) => (
      <article class="practice-card">
        <img src={icon} alt="" width="160" height="160" loading="lazy" />
        <h3>{title}</h3>
        <p>{description}</p>
      </article>
    ))
  }
</div>

<style>
  .practice-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .practice-card {
    min-height: 17rem;
    padding: 1.35rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.76);
    box-shadow: 0 18px 42px rgba(51, 56, 142, 0.08);
  }

  .practice-card img {
    width: 4.4rem;
    height: 4.4rem;
    margin-bottom: 1.1rem;
    object-fit: contain;
  }

  .practice-card h3 {
    margin-bottom: 0.7rem;
  }

  .practice-card p {
    margin-bottom: 0;
  }

  @media (max-width: 860px) {
    .practice-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .practice-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
